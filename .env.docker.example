COMPOSE_PROJECT_NAME=aus-ele

# Host ports. Change these if Baota already has other containers using them.
WEB_HOST_PORT=18080
API_HOST_PORT=18085
REDIS_HOST_PORT=16379

# Use /api when web and backend are served from the same host via nginx.
VITE_API_BASE=/api
NPM_REGISTRY=https://registry.npmjs.org/

# Backend runtime
AUS_ELE_ENABLE_SCHEDULER=true
AUS_ELE_CORS_ALLOW_ORIGINS=http://localhost:18080,http://127.0.0.1:18080
AUS_ELE_CORS_ALLOW_CREDENTIALS=false

# Optional Fingrid integration
FINGRID_API_KEY=
FINGRID_BASE_URL=https://data.fingrid.fi/api
FINGRID_REQUEST_INTERVAL_SECONDS=6.5
FINGRID_TIMEOUT_SECONDS=30
FINGRID_DEFAULT_BACKFILL_START=2014-01-01T00:00:00Z
FINGRID_DEFAULT_INCREMENTAL_LOOKBACK_DAYS=30
NORDPOOL_API_BASE_URL=https://data-api.nordpoolgroup.com
NORDPOOL_ACCESS_TOKEN=
NORDPOOL_API_KEY=
NORDPOOL_TOKEN_URL=
NORDPOOL_CLIENT_ID=
NORDPOOL_CLIENT_SECRET=
ENTSOE_API_BASE_URL=https://web-api.tp.entsoe.eu/api
ENTSOE_SECURITY_TOKEN=
ENTSOE_TIMEOUT_SECONDS=30

# Optional observability
AUS_ELE_OTEL_ENABLED=false
AUS_ELE_OTEL_EXPORTER=otlp
AUS_ELE_OTEL_EXPORTER_OTLP_ENDPOINT=
AUS_ELE_OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
AUS_ELE_OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=
AUS_ELE_OTEL_EXPORTER_OTLP_HEADERS=
AUS_ELE_OTEL_EXPORTER_OTLP_INSECURE=false
AUS_ELE_OTEL_METRICS_ENABLED=false
AUS_ELE_JSON_LOGS=false
AUS_ELE_LOG_AGGREGATION_ENABLED=false
AUS_ELE_LOG_AGGREGATION_SINK=file
AUS_ELE_LOG_AGGREGATION_FILE_PATH=/app/output/observability.jsonl
AUS_ELE_LOG_AGGREGATION_ENDPOINT=
AUS_ELE_OPENLINEAGE_ENABLED=false
AUS_ELE_OPENLINEAGE_SINK=none
AUS_ELE_OPENLINEAGE_ENDPOINT=
AUS_ELE_OPENLINEAGE_FILE_PATH=/app/output/openlineage-events.jsonl
