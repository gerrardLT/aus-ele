AUS_ELE_DB_PATH=G:\\project\\aus-ele\\data\\aemo_data.db
AUS_ELE_ENABLE_SCHEDULER=true
AUS_ELE_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
AUS_ELE_CORS_ALLOW_CREDENTIALS=false
REDIS_URL=redis://127.0.0.1:6379/0

# Optional observability
AUS_ELE_OTEL_ENABLED=false
